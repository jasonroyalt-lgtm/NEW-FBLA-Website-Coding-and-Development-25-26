<!DOCTYPE HTML>
<html>
    <!--Header which includes title of each page  of website, a link to the CSS stylesheet, a link to bootstrap 4.5.2 to make
    the website functional as the screen size shrinks marginally, and a link to the Poppins font used throughout the website.-->
    <head>
        <title>Search Item</title>
        <link rel = "stylesheet" type = "text/css" href = "style.css">
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;700&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    </head>    

    <body>
        <!--Navigational bar containing a link to all other pages on the website, as well as an option for administrators
        to log in or sign up to the backend system.-->
        <ul class = nav>
            <li class = "nav-item"><a href ="index.html">FMHS LOCATE</a></li>
            <li class = "nav-item"><a href = "index.html">Home</a></li>
            <li class = "nav-item"><a href = "about.html">About Us</a></li>
            <li class = "nav-item"><a href = "report-item.html">Report Item</a></li>
            <li  class = "nav-item"><a href = "search-item.ejs">Search Item</a></li>
            <li  class = "nav-item"><a href = ""><a href="signup.html">Sign up</a></li>
            <li  class = "nav-item"><a href = ""><a href="login.html">Log in</a></li>   
        </ul>

        <div class="search">
            <h1><b>Item search</b></h1>
            <input type="search" placeholder="Search for item" id="search-bar">
        </div>


        <div class="item-container">
            <% itemList.forEach(item => { %>
                <div class="item-card">
                    <h3><%= item.item %></h3>
                    <h6>
                        Submitted by: <%= item.fname %> <%= item.lname %>
                    </h6>

                    <p><%= item.itemDesc %></p>
                </div>           
            <% }) %>
        </div>    

        <!--Footer which includes links to other pages of the website, as well as a phone number, social media, and an address
        to contact the school. The footer also lists us three developers under the about us column.-->
        <footer>
            <div class="column">
                <h3><a href="about.html">About Us</a></h3>
                <h6>Developed by: Jason Thorndill, Kayden Zhang, Ace Shelton</h6>
            </div>
            <div class="column">
                <h3>Browse</h3>
                <h6><a href="index.html">Home</a></h6>
                <h6><a href="search-item.html">Item Search</a></h6>
                <h6><a href="report-item.html">Report Item</a></h6>
            </div>
            <div class="column">
                <h3>Contact us</h3>
                <h6>1102 Wildcat Ave.</h6>
                <h6>Fruita, CO, 81521</h6>
                <h6>Phone: (970)-254-6600</h6>
                <h6>Instagram: @Fruitamonumenthigh</h6>
                <h6>Facebook: @FruitaMonumentHigh</h6>
            </div>   
        </footer>   
        <script src="fetchAPI.js"></script> 
    </body>
</html>